<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Light Theme Colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#ac99ea</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDarkText">#9880e5</Color>
    <Color x:Key="Tertiary">#2B0B98</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#D600AA</Color>
    <Color x:Key="MidnightBlue">#190649</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <!-- Dark Theme Colors -->
    <Color x:Key="PrimaryDarkTheme">#6D4CFF</Color>
    <Color x:Key="SecondaryDarkTheme">#3A2D85</Color>
    <Color x:Key="TertiaryDarkTheme">#1E086F</Color>
    <Color x:Key="SurfaceDarkTheme">#121212</Color>
    <Color x:Key="OnSurfaceDarkTheme">#F5F5F5</Color>
    <Color x:Key="OnSurfaceVariantDarkTheme">#B3B3B3</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDarkTheme}}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource SecondaryDarkTheme}}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{AppThemeBinding Light={StaticResource Tertiary}, Dark={StaticResource TertiaryDarkTheme}}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="SurfaceBrush" Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource SurfaceDarkTheme}}"/>
    <SolidColorBrush x:Key="OnSurfaceBrush" Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource OnSurfaceDarkTheme}}"/>
    <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource OnSurfaceVariantDarkTheme}}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray500}}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray400}}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray200}}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray50}}"/>

</ResourceDictionary>