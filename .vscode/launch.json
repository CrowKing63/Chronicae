{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Server",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-server",
            "program": "${workspaceFolder}/Chronicae.Server.Windows/bin/Debug/net8.0/Chronicae.Server.Windows.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Chronicae.Server.Windows",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on\\s+(https?://\\S+)\\b",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Run Server and Client",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-server",
            "program": "${workspaceFolder}/Chronicae.Server.Windows/bin/Debug/net8.0/Chronicae.Server.Windows.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Chronicae.Server.Windows",
            "stopAtEntry": false,
            "internalConsoleOptions": "openOnSessionStart",
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        }
    ]
}